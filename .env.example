# =======================================
# CRICBET ARENA -- Environment Variables
# =======================================

# --- REQUIRED ---
# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here
# Bot Username (without @)
BOT_USERNAME=YourBotUsername

# Supabase (from supabase.com -> Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
# Cricket API Key (from cricapi.com -- free tier)
CRICKET_API_KEY=your_cricapi_key_here
# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789
ADMIN_CHAT_ID=123456789
# --- WEBHOOK (Production/Render) ---

# Set this to your Render URL for webhook mode
# Leave empty for polling mode (development)
WEBHOOK_URL=https://your-app.onrender.com
WEBHOOK_SECRET=your_random_secret_string
WEBHOOK_PATH=/webhook
PORT=8080
# --- OPTIONAL (defaults are fine) ---
# Betting Config
MIN_BET_AMOUNT=3
MAX_BET_AMOUNT=10000
PLATFORM_COMMISSION_PCT=16.67
BET_LOCK_BEFORE_MATCH_MINS=5
AUTO_CLOSE_ROOM_MINS=30
# Engagement
FREE_CREDITS_ON_SIGNUP=10
REFERRAL_BONUS=5
DAILY_FREE_BET_AMOUNT=1
MIN_WITHDRAWAL=50
# Rate Limiting
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW=60
# Logging
LOG_LEVEL=INFO
Where to Get Each Value
BOT_TOKEN: @BotFather on Telegram -> /newbot
BOT_USERNAME: The username you chose (without @)

SUPABASE_URL: Supabase -> Settings -> API -> Project URL
SUPABASE_KEY: Supabase -> Settings -> API -> service_role key
CRICKET_API_KEY: cricapi.com -> Dashboard -> API Key
ADMIN_IDS: Your Telegram ID (send /start to @userinfobot)






WEBHOOK_URL: Your Render app URL
WEBHOOK_SECRET: Any random string
